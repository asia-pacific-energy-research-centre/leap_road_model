# ===========================
# Python
# ===========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/

# ===========================
# Virtual environments
# ===========================
.venv/
venv/
env/

# ===========================
# IDE / OS
# ===========================
.vscode/
.idea/
.DS_Store
Thumbs.db
.env

# ===========================
# Logs and serialised data
# ===========================
*.log
*.pkl
*.parquet

# ===========================
# All generated outputs
# These are produced by running the model and are not committed.
# results/ and plotting_output/ are recreated on each run.
# ===========================
results/*
plotting_output/
intermediate_data/

# Commit lightweight dashboard HTML for deployment (served on HuggingFace Space).
# Keep bulky module outputs and static diagnostic PNG suites ignored.
# Git requires each directory level to be explicitly un-ignored when the parent is ignored.
!results/*/
# Smoke test and ad-hoc diagnostic run directories stay local only.
# These must come after !results/*/ so they take precedence and re-ignore those dirs.
results/codex_smoke*/
results/_codex_smoke*/
results/*_saturation_check/
results/*_rowdiag/
results/*_latest*/
results/*/*
!results/*/diagnostics/
results/*/diagnostics/*
!results/*/diagnostics/dashboard/
results/*/diagnostics/dashboard/*
!results/*/diagnostics/dashboard/*.html
!results/shared/
results/shared/*
!results/shared/dashboard_assets/
!results/shared/dashboard_assets/**

# ===========================
# Runtime-written Module 1 inputs
# Written at runtime by road_model_inputs_interface; not committed.
# The directory is created automatically on first run.
# ===========================
input_data/module1_defaults/

# ===========================
# Raw unprocessed external data
# Not needed by the model code; keep locally only.
# ===========================
input_data/unprocessed data/

# Commit the deployment-ready data files (generated by scripts/prepare_esto_for_deployment.py)
!input_data/esto_transport_2000_2022.csv
!input_data/9th_macro_data.csv

# ===========================
# Images
# Generated output PNGs are excluded; doc diagrams are committed.
# ===========================
*.png
*.jpg
*.jpeg
!docs/**/*.png
!results/shared/dashboard_assets/*.png
